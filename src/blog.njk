---
layout: base.njk
title: Tree Care Blog
description: Tree care tips, seasonal guides, and advice from Ben Bivins Tree Experts serving Ocean & Monmouth County, NJ.
permalink: /blog.html
bodyClass: is-blog
---
<section class="page-hero">
  <div class="container">
    <nav class="crumb"><a href="/index.html">Home</a> <span>›</span> Blog</nav>
    <h1>Tree Care Blog</h1>
  </div>
</section>
<main class="page-main">
  <div class="container page-wrap">
    <div class="blog-grid">
      {% for post in collections.posts %}
      <article class="blog-card">
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {% if post.data.date %}<p class="blog-card__date">{{ post.data.date | readableDate }}</p>{% endif %}
        <p>{{ post.data.summary }}</p>
        <a class="blog-card__link" href="{{ post.url }}">Read more →</a>
      </article>
      {% endfor %}
    </div>
  </div>
</main>
